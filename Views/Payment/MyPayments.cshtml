@model IEnumerable<EventManagementPortal.Models.Payment>
@{
    ViewData["Title"] = "My Payments";
}

<div class="container py-5 mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="hero-badge mb-2">
                <span class="live-dot"></span>
                Payment telemetry
            </div>
            <h2 class="mb-0 h-jakarta text-white">My Payments</h2>
        </div>
        <a asp-controller="Registration" asp-action="MyRegistrations" class="btn btn-primary">Upload from registrations</a>
    </div>

    @if (!Model.Any())
    {
        <div class="glass-panel p-4 text-center text-muted">No payments uploaded yet.</div>
    }
    else
    {
        <div class="table-responsive glass-panel p-2">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Competition</th>
                        <th>Screenshot</th>
                        <th>Status</th>
                        <th>Submitted</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var badgeClass = item.Status == EventManagementPortal.Models.PaymentStatuses.Approved ? "badge-open"
                            : item.Status == EventManagementPortal.Models.PaymentStatuses.Rejected ? "bg-danger" : "badge-few";
                        <tr>
                            <td>@item.Registration!.Competition.Name</td>
                            <td><a href="@item.Screenshot" target="_blank" class="btn btn-sm btn-outline-light">View</a></td>
                            <td><span class="badge @badgeClass">@item.Status</span></td>
                            <td>@item.SubmittedAt.ToString("dd MMM yyyy, hh:mm tt")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
