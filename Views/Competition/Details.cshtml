@model EventManagementPortal.Models.Competition
@{
    ViewData["Title"] = "Competition Details";
}

@if (TempData["SuccessMessage"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">@ok<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["ErrorMessage"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">@err<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">@Model.Name</h2>
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Back to Competitions</a>
</div>

<div class="card shadow-sm mb-4" data-competition-id="@Model.CompetitionID">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <p class="mb-1"><strong>Event</strong></p>
                <p class="text-muted">@Model.Event.Name</p>
            </div>
            <div class="col-md-6">
                <p class="mb-1"><strong>Department (event)</strong></p>
                <p class="text-muted">@Model.Event.Department</p>
            </div>
            <div class="col-12">
                <p class="mb-1"><strong>Description</strong></p>
                <p class="text-muted">@(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</p>
            </div>
            <div class="col-md-6">
                <p class="mb-1"><strong>Location</strong></p>
                <p class="text-muted">@Model.Location</p>
            </div>
            <div class="col-md-6">
                <p class="mb-1"><strong>Entry fee</strong></p>
                <p class="text-muted">@Model.EntryFee.ToString("0.00")</p>
            </div>
            <div class="col-md-6">
                <p class="mb-1"><strong>Start date</strong></p>
                <p class="text-muted">@Model.StartDate.ToString("dd MMM yyyy")</p>
            </div>
            <div class="col-md-6">
                <p class="mb-1"><strong>End date</strong></p>
                <p class="text-muted">@Model.EndDate.ToString("dd MMM yyyy")</p>
            </div>
            <div class="col-md-6">
                <p class="mb-1"><strong>Max team size</strong></p>
                <p class="text-muted">@Model.MaxTeamSize</p>
            </div>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 align-items-center">
    @if (User.IsInRole(AppRoles.Organizer) || User.IsInRole(AppRoles.Admin))
    {
        <a asp-controller="StaffAssignment"
           asp-action="Competition"
           asp-route-id="@Model.CompetitionID"
           class="btn btn-outline-warning">
            Manage volunteer assignments
        </a>
    }

    @if (User.IsInRole(AppRoles.Student))
    {
        <div class="d-flex flex-column gap-2">
            @if (Model.MaxTeamSize > 1)
            {
                <p class="text-muted small mb-0">Team competition: you will enter all @Model.MaxTeamSize members (including you) on the next page.</p>
            }
            <a asp-controller="Registration"
               asp-action="Create"
               asp-route-competitionId="@Model.CompetitionID"
               class="btn btn-primary btn-lg align-self-start">
                Register for this competition
            </a>
        </div>
    }
    else if (User.Identity?.IsAuthenticated ?? false)
    {
        <p class="text-muted mb-0">
            Only <strong>Student</strong> accounts can register for competitions.
            Sign in with a student account, or create one from Register.
        </p>
    }
    else
    {
        var returnUrl = Url.Action("Create", "Registration", new { competitionId = Model.CompetitionID }) ?? "/";
        <a asp-controller="Account"
           asp-action="Login"
           asp-route-returnUrl="@returnUrl"
           class="btn btn-primary btn-lg">
            Log in to register
        </a>
        <span class="text-muted align-self-center">Student account required.</span>
    }
</div>
