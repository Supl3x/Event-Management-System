@model IEnumerable<EventManagementPortal.Models.Competition>
@{
    ViewData["Title"] = "Competitions";
}

<div class="container py-5 mt-2">
    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success alert-dismissible fade show glass-panel mb-4" role="alert">
            @success
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <div class="hero-badge mb-2">
                <span class="live-dot"></span>
                Competition network online
            </div>
            <h2 class="mb-0 h-jakarta text-white">Competitions Arena</h2>
        </div>
        @if (User.IsInRole(AppRoles.Admin))
        {
            <a asp-action="Create" class="btn btn-create">Create competition</a>
        }
    </div>

    <div class="row g-4">
        @foreach (var competition in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="comp-stat-icon mb-3"><i class="fa-solid fa-trophy"></i></div>
                        <h5 class="card-title text-white h-jakarta">@competition.Name</h5>
                        <p class="card-text text-muted small mb-2">Event: @competition.Event.Name</p>
                        <p class="card-text mb-2"><strong>Starts:</strong> @competition.StartDate.ToString("dd MMM yyyy")</p>
                        <p class="card-text mb-4"><strong>Location:</strong> @competition.Location</p>
                        <a asp-action="Details" asp-route-id="@competition.CompetitionID" class="btn btn-primary mt-auto">View details</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
