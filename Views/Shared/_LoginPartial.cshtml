@using System.Security.Claims

<ul class="navbar-nav align-items-center gap-2 nav-auth-menu">
@if (User.Identity?.IsAuthenticated ?? false)
{
    var displayName = User.FindFirstValue(ClaimTypes.GivenName)
        ?? User.Identity?.Name?.Split('@')[0]
        ?? "User";
    var roleLabel = User.IsInRole("Admin") ? "Admin"
        : User.IsInRole("Organizer") ? "Organizer"
        : User.IsInRole("Volunteer") ? "Volunteer"
        : User.IsInRole("Student") ? "Student"
        : "User";
    var shortDisplayName = displayName
        .Split(' ', System.StringSplitOptions.RemoveEmptyEntries)
        .FirstOrDefault() ?? displayName;
    <li class="nav-item dropdown position-relative">
        <a class="nav-link d-flex align-items-center gap-2 p-0 nav-profile-trigger"
           href="#"
           id="userDropdownBtn"
           role="button"
           data-bs-toggle="dropdown"
           aria-expanded="false"
           title="@displayName">
            <div class="user-avatar-sm">
                <i class="fa-solid fa-user-astronaut"></i>
            </div>
            <span class="d-none d-xl-inline text-light small nav-display-name nav-display-name--full">@displayName</span>
            <span class="d-inline d-xl-none text-light small nav-display-name nav-display-name--compact">@shortDisplayName</span>
            <span class="badge role-pill-dynamic d-none d-xxl-inline">@roleLabel</span>
        </a>
        
        <ul class="dropdown-menu dropdown-menu-end p-2 shadow-lg border-0 mt-2 neon-dropdown" 
            id="userDropdownMenu"
            style="min-width: 210px;">
            
            <li class="px-3 py-3 border-bottom border-white border-opacity-10 mb-2">
                <div class="text-cyan fw-bold small mb-0">Portal Identity</div>
                <div class="text-muted small">@User.Identity?.Name</div>
            </li>

            <li>
                <a class="dropdown-item rounded-2 d-flex align-items-center gap-3 py-2" asp-controller="Dashboard" asp-action="Index">
                    <i class="fa-solid fa-gauge-high text-cyan"></i> 
                    <span class="text-white">Command Center</span>
                </a>
            </li>
            
            <li><hr class="dropdown-divider border-white opacity-10"></li>
            
            <li>
                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                    <button type="submit" class="dropdown-item rounded-2 d-flex align-items-center gap-3 py-2 text-danger w-100 border-0 bg-transparent text-start fw-bold">
                        <i class="fa-solid fa-right-from-bracket"></i> 
                        <span>Logout</span>
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
    <li class="nav-item"><a class="btn btn-cyan btn-sm px-4 rounded-pill fw-bold" asp-controller="Account" asp-action="Register">Sign Up</a></li>
}
</ul>