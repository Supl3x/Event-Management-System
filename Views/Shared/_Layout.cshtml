@inject IConfiguration Configuration
@inject EventManagementPortal.Data.ApplicationDbContext DbContext
@using EventManagementPortal.Infrastructure
@using Microsoft.EntityFrameworkCore
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventHub NED</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EventManagementPortal.styles.css" asp-append-version="true" />
    <style>
        header {
            position: relative;
            z-index: 5000;
        }

        .navbar-emp {
            position: relative;
            z-index: 5001;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100 neon-app">
    <header>
        <nav class="navbar navbar-expand-xl navbar-dark navbar-emp">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <div class="brand-mark">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="white"><path d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1z"/></svg>
                    </div>
                    <span>EventHub — NED</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0 ms-md-4 gap-md-1">
                        @{
                            var hasUnreadNotifications = false;
                            if (User.Identity?.IsAuthenticated ?? false)
                            {
                                var layoutUserId = User.GetUserId();
                                if (layoutUserId is not null)
                                {
                                    hasUnreadNotifications = await DbContext.Notifications
                                        .AsNoTracking()
                                        .AnyAsync(n => n.UserID == layoutUserId.Value && !n.IsRead);
                                }
                            }
                        }
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" 
                               asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Event" ? "active" : "")" 
                               asp-controller="Event" asp-action="Index">Events</a>
                        </li>
                        
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")" 
                                   asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Notification" ? "active" : "")"
                                   asp-controller="Notification" asp-action="Index">
                                    Notifications
                                    @if (hasUnreadNotifications)
                                    {
                                        <span class="ms-1 d-inline-block rounded-circle" style="width:8px;height:8px;background:#22c55e;box-shadow:0 0 0 2px rgba(34,197,94,0.25);"></span>
                                    }
                                </a>
                            </li>
                            
                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Dashboard" asp-action="Student">Student Hub</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Registration" asp-action="MyRegistrations">My Tickets</a>
                                </li>
                            }

                            @if (User.IsInRole("Organizer"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Event" asp-action="Create">Create Event</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Competition" asp-action="Create">Create Competition</a>
                                </li>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="RoleManagement" asp-action="Index">Role Management</a>
                                </li>
                            }

                            @if (User.IsInRole("Volunteer"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Payment" asp-action="Verify">Verify Payments</a>
                                </li>
                            }
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-2 ms-xl-3 nav-right-tools">
                        <div class="theme-intensity-wrap">
                            <label for="themeIntensitySelect" class="theme-intensity-label">FX</label>
                            <select id="themeIntensitySelect" class="form-select form-select-sm theme-intensity-select" aria-label="Theme intensity">
                                <option value="cinematic">Cinematic</option>
                                <option value="high">High</option>
                                <option value="balanced">Balanced</option>
                                <option value="light">Light</option>
                            </select>
                        </div>
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="neon-bg-orb neon-bg-orb--left" aria-hidden="true"></div>
    <div class="neon-bg-orb neon-bg-orb--right" aria-hidden="true"></div>
    <div class="neon-grid-overlay" aria-hidden="true"></div>

    <main role="main" class="flex-shrink-0 app-main pb-5">
        <div class="container app-shell py-4 py-lg-5">
            @RenderBody()
        </div>
    </main>

    <footer class="footer-emp mt-auto">
        <div class="container d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
            <div class="footer-brand">EventHub — NED · 2026</div>
            <div class="d-flex gap-4">
                <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none" style="color: inherit;">Privacy</a>
                <span style="color: rgba(255,255,255,0.05)">|</span>
                <span>Smart NED Campus Portal</span>
            </div>
        </div>
    </footer>

    @* JavaScript Priority Order *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/realtime.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>