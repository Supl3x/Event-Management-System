@model EventManagementPortal.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-12">
        <h2>Welcome, @Model.UserName</h2>
        <p class="text-muted mb-0">Roles: @(Model.Roles.Count == 0 ? "No role assigned" : string.Join(", ", Model.Roles))</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Upcoming events</h5>
                <p class="display-6 mb-0">@Model.UpcomingEventsCount</p>
                <a asp-controller="Event" asp-action="Index" class="stretched-link text-decoration-none small">Browse events →</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Open competitions</h5>
                <p class="display-6 mb-0">@Model.OpenCompetitionsCount</p>
                <a asp-controller="Competition" asp-action="Index" class="stretched-link text-decoration-none small">Browse competitions →</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">My registrations</h5>
                <p class="display-6 mb-0">@Model.MyRegistrationsCount</p>
                <a asp-controller="Registration" asp-action="MyRegistrations" class="stretched-link text-decoration-none small">View list →</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    @if (User.IsInRole(AppRoles.Admin))
    {
        <div class="col-md-6 col-lg-4">
            <div class="card border-primary h-100">
                <div class="card-body">
                    <h5 class="card-title">Admin</h5>
                    <p class="card-text small text-muted">Create competitions under an event. Payment verification is done by organizers or volunteers (per database rules).</p>
                    <a asp-controller="Competition" asp-action="Create" class="btn btn-primary btn-sm">Create competition</a>
                </div>
            </div>
        </div>
    }
    @if (User.IsInRole(AppRoles.Organizer))
    {
        <div class="col-md-6 col-lg-4">
            <div class="card border-success h-100">
                <div class="card-body">
                    <h5 class="card-title">Organizer</h5>
                    <p class="card-text small text-muted">Events own competitions. Create the event first. You can verify student payments.</p>
                    <a asp-controller="Event" asp-action="Create" class="btn btn-success btn-sm">Create event</a>
                    <a asp-controller="Event" asp-action="Index" class="btn btn-outline-success btn-sm ms-1">My events list</a>
                    <a asp-controller="Payment" asp-action="Verify" class="btn btn-outline-primary btn-sm ms-1">Verify payments</a>
                </div>
            </div>
        </div>
    }
    @if (User.IsInRole(AppRoles.Volunteer))
    {
        <div class="col-md-6 col-lg-4">
            <div class="card border-warning h-100">
                <div class="card-body">
                    <h5 class="card-title">Volunteer</h5>
                    <p class="card-text small text-muted">Verify payment proofs submitted by students.</p>
                    <a asp-controller="Payment" asp-action="Verify" class="btn btn-warning btn-sm text-dark">Verify payments</a>
                </div>
            </div>
        </div>
    }
    @if (User.IsInRole(AppRoles.Student))
    {
        <div class="col-md-6 col-lg-4">
            <div class="card border-info h-100">
                <div class="card-body">
                    <h5 class="card-title">Student</h5>
                    <p class="card-text small text-muted">Register from a competition page, then upload payment if required.</p>
                    <a asp-controller="Competition" asp-action="Index" class="btn btn-info btn-sm text-dark">Browse competitions</a>
                    <a asp-controller="Registration" asp-action="MyRegistrations" class="btn btn-outline-info btn-sm ms-1 text-dark">Registrations</a>
                </div>
            </div>
        </div>
    }
</div>
