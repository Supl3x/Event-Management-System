@model EventManagementPortal.Models.DashboardViewModel
@{
    ViewData["Title"] = "Command Center";
}

<div class="container py-5 mt-3">
    @* ── Header Section ── *@
    <div class="row mb-5 align-items-center">
        <div class="col-md-9">
            <div class="hero-badge">
                <div class="live-dot"></div>
                Operational Status: Active @DateTime.Now.Year
            </div>
            <h1 class="display-4 text-white mb-2">Welcome, <span class="text-gradient">@Model.UserName</span></h1>
            <p class="text-muted s-grotesk fs-5">
                Authorized Roles: 
                @foreach(var role in Model.Roles) {
                    <span class="role-pill-dynamic">@role</span>
                }
            </p>
        </div>
        <div class="col-md-3 text-md-end">
             <div class="user-avatar-sm user-avatar-lg">
                <i class="fa-solid fa-user-gear"></i>
            </div>
        </div>
    </div>

    @* ── Premium Stats Grid ── *@
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="saas-card p-4 h-100 position-relative overflow-hidden">
                <div class="hero-glow"></div> @* Glow from your CSS *@
                <div class="comp-stat-icon mb-3">
                    <i class="fa-solid fa-calendar-circle-exclamation"></i>
                </div>
                <h5 class="text-muted small text-uppercase tracking-wider mb-2">Upcoming Events</h5>
                <div class="display-5 fw-bold text-white mb-3">@Model.UpcomingEventsCount</div>
                <a asp-controller="Event" asp-action="Index" class="text-cyan text-decoration-none small s-grotesk">
                    Access Registry <i class="fa-solid fa-arrow-right-long ms-2"></i>
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="saas-card p-4 h-100 position-relative overflow-hidden">
                <div class="hero-glow-right"></div> @* Glow from your CSS *@
                <div class="comp-stat-icon mb-3" style="color: var(--cyan-400); border-color: var(--cyan-glow);">
                    <i class="fa-solid fa-microchip-ai"></i>
                </div>
                <h5 class="text-muted small text-uppercase tracking-wider mb-2">Open Competitions</h5>
                <div class="display-5 fw-bold text-white mb-3">@Model.OpenCompetitionsCount</div>
                <a asp-controller="Competition" asp-action="Index" class="text-cyan text-decoration-none small s-grotesk">
                    Browse Arena <i class="fa-solid fa-arrow-right-long ms-2"></i>
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="saas-card p-4 h-100">
                <div class="comp-stat-icon mb-3" style="color: #fb923c; background: rgba(249, 115, 22, 0.1); border-color: rgba(249, 115, 22, 0.2);">
                    <i class="fa-solid fa-ticket-perforated"></i>
                </div>
                <h5 class="text-muted small text-uppercase tracking-wider mb-2">My Registrations</h5>
                <div class="display-5 fw-bold text-white mb-3">@Model.MyRegistrationsCount</div>
                <a asp-controller="Registration" asp-action="MyRegistrations" class="text-cyan text-decoration-none small s-grotesk">
                    Manage Tickets <i class="fa-solid fa-arrow-right-long ms-2"></i>
                </a>
            </div>
        </div>
    </div>

    @* ── Operational Modules ── *@
    <h3 class="text-white mb-4 h-jakarta">Management Terminals</h3>
    <div class="row g-4">
        @if (User.IsInRole(AppRoles.Student))
        {
            <div class="col-lg-7">
                <div class="saas-card p-5 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h4 class="text-white h-jakarta mb-1">Student Hub</h4>
                            <p class="text-muted small mb-0">Submit volunteer requests for specific events and track approvals.</p>
                        </div>
                        <span class="badge-live px-3 py-1 rounded-pill small">Student</span>
                    </div>

                    <div class="d-flex flex-wrap gap-3">
                        <a asp-controller="Dashboard" asp-action="Student" class="btn btn-primary px-4">
                            <i class="fa-solid fa-handshake-angle me-2"></i> Open Student Hub
                        </a>
                        <a asp-controller="Registration" asp-action="MyRegistrations" class="btn btn-outline-light px-4">
                            <i class="fa-solid fa-ticket me-2"></i> My Registrations
                        </a>
                    </div>
                </div>
            </div>
        }

        @if (User.IsInRole(AppRoles.Organizer))
        {
            <div class="col-lg-7">
                <div class="saas-card p-5 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h4 class="text-white h-jakarta mb-1">Organizer Operations</h4>
                            <p class="text-muted small mb-0">Events ownership and payment verification protocols.</p>
                        </div>
                        <span class="badge-live px-3 py-1 rounded-pill small">Level: Admin</span>
                    </div>
                    
                    <div class="d-flex flex-wrap gap-3">
                        <a asp-controller="Event" asp-action="Create" class="btn btn-primary px-4">
                            <i class="fa-solid fa-plus-circle me-2"></i> Create Event
                        </a>
                        <a asp-controller="Event" asp-action="Index" class="btn btn-outline-light px-4">
                            <i class="fa-solid fa-folder-open me-2"></i> Events List
                        </a>
                        <a asp-controller="RoleRequest" asp-action="OrganizerVolunteerRequests" class="btn btn-outline-info px-4">
                            <i class="fa-solid fa-handshake-angle me-2"></i> Volunteer Requests
                        </a>
                        <a asp-controller="Payment" asp-action="Verify" class="btn btn-cyan px-4">
                            <i class="fa-solid fa-shield-check me-2"></i> Verify Payments
                        </a>
                    </div>
                </div>
            </div>
        }

        <div class="col-lg-5">
            <div class="saas-card p-4 h-100" style="border-style: dashed !important; background: rgba(2, 132, 199, 0.02);">
                <h5 class="text-white h-jakarta mb-4"><i class="fa-solid fa-circle-info text-cyan me-2"></i> Quick Workflow</h5>
                <div class="small">
                    <div class="d-flex gap-3 mb-3">
                        <div class="text-cyan fw-bold">01</div>
                        <div class="text-muted">Register a master event (Olympiad, TechWeek).</div>
                    </div>
                    <div class="d-flex gap-3 mb-3">
                        <div class="text-cyan fw-bold">02</div>
                        <div class="text-muted">Organizers/admins map competitions and assign volunteers.</div>
                    </div>
                    <div class="d-flex gap-3">
                        <div class="text-cyan fw-bold">03</div>
                        <div class="text-muted">Verify student bank receipts via Payment Desk.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (User.IsInRole(AppRoles.Admin))
    {
        <div class="mt-4">
            <a asp-controller="RoleManagement" asp-action="Index" class="btn btn-outline-warning">
                Open role management
            </a>
        </div>
    }
</div>