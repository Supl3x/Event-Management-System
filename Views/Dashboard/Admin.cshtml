@{
    ViewData["Title"] = "Admin Hub";
}

<div class="container py-5 mt-3">
    <div class="row align-items-end mb-5">
        <div class="col-lg-8">
            <div class="hero-badge mb-3">
                <div class="live-dot"></div>
                Administration command
            </div>
            <h1 class="h-jakarta fw-bold text-white display-5 mb-0">Admin Hub</h1>
            <p class="text-muted s-grotesk fs-5 mt-2 mb-0">Review role requests, assign platform roles, and supervise operations.</p>
        </div>
        <div class="col-lg-4 text-lg-end mt-4">
            <a asp-controller="RoleManagement" asp-action="Index" class="btn btn-primary px-4">
                <i class="fa-solid fa-user-shield me-2"></i>Open role management
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="saas-card p-4 h-100">
                <div class="comp-stat-icon mb-3"><i class="fa-solid fa-list-check"></i></div>
                <h5 class="text-white h-jakarta mb-2">Role Requests</h5>
                <p class="text-muted mb-4">Approve or reject organizer role requests submitted by student accounts.</p>
                <a asp-controller="RoleManagement" asp-action="Index" class="btn btn-outline-light btn-sm">Review requests</a>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="saas-card p-4 h-100">
                <div class="comp-stat-icon mb-3"><i class="fa-solid fa-trophy"></i></div>
                <h5 class="text-white h-jakarta mb-2">Competition Control</h5>
                <p class="text-muted mb-4">Create competitions under events and verify scheduling and limits.</p>
                <a asp-controller="Competition" asp-action="Create" class="btn btn-outline-light btn-sm">Create competition</a>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="saas-card p-4 h-100">
                <div class="comp-stat-icon mb-3"><i class="fa-solid fa-calendar-days"></i></div>
                <h5 class="text-white h-jakarta mb-2">Event Overview</h5>
                <p class="text-muted mb-4">Browse active events and navigate to volunteer assignment areas.</p>
                <a asp-controller="Event" asp-action="Index" class="btn btn-outline-light btn-sm">Browse events</a>
            </div>
        </div>
    </div>
</div>
