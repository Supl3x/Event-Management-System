@using System.Security.Claims
@{
    ViewData["Title"] = "Organizer Hub";
    var userName = User.FindFirstValue(ClaimTypes.GivenName) ?? User.Identity?.Name?.Split('@')[0] ?? "Organizer";
}

<div class="container py-5 mt-3">
    @* ── Header Area ── *@
    <div class="row align-items-end mb-5">
        <div class="col-lg-7">
            <div class="d-flex align-items-center gap-2 mb-3">
                <div class="live-dot" style="width:10px; height:10px;"></div>
                <span class="s-grotesk text-cyan text-uppercase fw-medium tracking-wider" style="font-size: 12px;">Operational Command Center</span>
            </div>
            <h1 class="h-jakarta fw-bold text-white display-5 mb-0">
                Welcome back, <span class="text-cyan">@userName</span>
            </h1>
            <p class="text-muted s-grotesk fs-5 mt-2 mb-0">Control your events, track revenue, and manage student logistics.</p>
        </div>
        <div class="col-lg-5 text-lg-end mt-4">
            <a asp-controller="Event" asp-action="Create" class="btn btn-create h-jakarta">
                <i class="fa-solid fa-plus-circle me-2"></i> Create New Event
            </a>
            <a asp-controller="Competition" asp-action="Create" class="btn btn-outline-light h-jakarta ms-2">
                <i class="fa-solid fa-trophy me-2"></i> Create Competition
            </a>
        </div>
    </div>

    @* ── Statistics Row ── *@
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="glass-panel p-4 h-100">
                <div class="stat-circle icon-blue"><i class="fa-solid fa-calendar-days"></i></div>
                <h3 class="text-white h-jakarta fw-bold mb-1">0</h3>
                <p class="s-grotesk text-muted small mb-0 fw-medium">TOTAL EVENTS HOSTED</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-panel p-4 h-100">
                <div class="stat-circle icon-cyan"><i class="fa-solid fa-users-viewfinder"></i></div>
                <h3 class="text-white h-jakarta fw-bold mb-1">0</h3>
                <p class="s-grotesk text-muted small mb-0 fw-medium">ACTIVE COMPETITIONS</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-panel p-4 h-100">
                <div class="stat-circle icon-gold"><i class="fa-solid fa-sack-dollar"></i></div>
                <h3 class="text-white h-jakarta fw-bold mb-1">0</h3>
                <p class="s-grotesk text-muted small mb-0 fw-medium">AWAITING VERIFICATION</p>
            </div>
        </div>
    </div>

    @* ── Main Operations Grid ── *@
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="glass-panel h-100">
                <div class="row g-0 h-100">
                    <div class="col-md-6 border-end border-white border-opacity-10">
                        <a asp-controller="Event" asp-action="Index" class="op-card">
                            <h4 class="text-white h-jakarta mb-3">Event Registry</h4>
                            <p class="text-muted s-grotesk small mb-4">View and edit your events. Monitor registration counts and competition details in real-time.</p>
                            <span class="arrow-link">Manage Events <i class="fa-solid fa-arrow-right-long ms-2"></i></span>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a asp-controller="Competition" asp-action="Create" class="op-card">
                            <h4 class="text-white h-jakarta mb-3">Competition Desk</h4>
                            <p class="text-muted s-grotesk small mb-4">Create competitions under your events with correct date windows, fees, and team size limits.</p>
                            <span class="arrow-link">Create Competition <i class="fa-solid fa-arrow-right-long ms-2"></i></span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="glass-panel p-4 p-xl-5">
                <h5 class="text-white h-jakarta mb-4 d-flex align-items-center">
                    <i class="fa-solid fa-rocket text-cyan me-3"></i> Quick Guide
                </h5>
                
                <div class="step-item">
                    <div class="text-white fw-bold mb-1">Initial Launch</div>
                    <p class="text-muted small s-grotesk mb-0">Register your event details like TechWeek or Funtasia first.</p>
                </div>

                <div class="step-item">
                    <div class="text-white fw-bold mb-1">Link Competitions</div>
                    <p class="text-muted small s-grotesk mb-0">Create competitions or coordinate with admins to map them to your events.</p>
                </div>

                <div class="step-item">
                    <div class="text-white fw-bold mb-1">Gate Pass Approval</div>
                    <p class="text-muted small s-grotesk mb-0">Check the Payment Desk daily to approve pending student entries.</p>
                </div>
            </div>
        </div>
    </div>
</div>