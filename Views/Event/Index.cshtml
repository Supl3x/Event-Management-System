@model IEnumerable<EventManagementPortal.Models.Event>
@{
    ViewData["Title"] = "Events";
}

@if (TempData["SuccessMessage"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="mb-0">Events</h2>
    @if (User.IsInRole(AppRoles.Organizer))
    {
        <a asp-action="Create" class="btn btn-success">Create event</a>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No events listed yet.</div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Name</h5>
                        <p class="card-text small text-muted mb-2">@item.Department</p>
                        <p class="card-text mb-2"><strong>Starts:</strong> @item.StartDate.ToString("dd MMM yyyy")</p>
                        <p class="card-text mb-2"><strong>Location:</strong> @item.Location</p>
                        <p class="card-text small mb-4">Organizer: @item.Creator.User.Name</p>
                        <a asp-action="Details" asp-route-id="@item.EventID" class="btn btn-primary mt-auto">Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
