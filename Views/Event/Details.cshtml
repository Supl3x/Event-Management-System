@model EventManagementPortal.Models.Event
@{
    ViewData["Title"] = "Event Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">@Model.Name</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to events</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <p class="mb-1"><strong>Department</strong></p>
                <p class="text-muted">@Model.Department</p>
            </div>
            <div class="col-md-6">
                <p class="mb-1"><strong>Location</strong></p>
                <p class="text-muted">@Model.Location</p>
            </div>
            <div class="col-md-6">
                <p class="mb-1"><strong>Start date</strong></p>
                <p class="text-muted">@Model.StartDate.ToString("dd MMM yyyy")</p>
            </div>
            <div class="col-md-6">
                <p class="mb-1"><strong>End date</strong></p>
                <p class="text-muted">@Model.EndDate.ToString("dd MMM yyyy")</p>
            </div>
            <div class="col-md-6">
                <p class="mb-1"><strong>Created by</strong></p>
                <p class="text-muted">@Model.Creator.User.Name (@Model.Creator.User.Email)</p>
            </div>
        </div>
    </div>
</div>
