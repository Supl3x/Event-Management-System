@model IEnumerable<EventManagementPortal.Models.Competition>
@{
    ViewData["Title"] = "Home";
}

<div class="hero-strip">
    <h1>Discover competitions</h1>
    <p>Browse events, register as a student, and track payments — all in one place.</p>
</div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h2 class="mb-0">Upcoming competitions</h2>
    <a asp-controller="Competition" asp-action="Index" class="btn btn-outline-primary btn-sm">View all</a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body empty-state">
            <p class="mb-2 fw-semibold text-body">No competitions yet</p>
            <p class="small mb-0">Check back later or explore <a asp-controller="Event" asp-action="Index">events</a>.</p>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var competition in Model)
        {
            <div class="col-md-6 col-lg-4" data-competition-id="@competition.CompetitionID">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@competition.Name</h5>
                        <p class="card-text small text-muted mb-2">@competition.Event.Name</p>
                        <p class="card-text mb-2 small">
                            <span class="text-secondary">Date</span><br />
                            @competition.StartDate.ToString("dd MMM yyyy")
                        </p>
                        <p class="card-text small text-muted mb-2">
                            <span class="text-secondary">Location</span><br />
                            @competition.Location
                        </p>
                        <p class="card-text mb-4 small">
                            <span class="text-secondary">Entry fee</span><br />
                            <span class="fw-semibold text-body">@competition.EntryFee.ToString("0.00")</span>
                        </p>
                        <a asp-controller="Competition"
                           asp-action="Details"
                           asp-route-id="@competition.CompetitionID"
                           class="btn btn-primary mt-auto">
                            View details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
